{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "lib": ["esnext"],
        "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
        "strict": false,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": ["jest", "node"]
    },
    "include": ["src/**/*.ts"]
}